{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "files": {
    "includes": ["!**/.source", "!**/*.mdx"]
  },
  "linter": {
    "rules": {
      "a11y": {
        "useAnchorContent": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  }
}
