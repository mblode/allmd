{
  "name": "@allmd/web",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless allmd next dev",
    "build": "node scripts/build-well-known-skills.mjs && next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check-types": "next typegen && tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run check-types",
    "fix": "npm run format && npm run lint:fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@next/third-parties": "^16.1.6",
    "@tailwindcss/typography": "^0.5.19",
    "blode-icons-react": "^0.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "griffo": "^1.0.0",
    "motion": "^12.37.0",
    "next": "16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "tailwindcss": "^4",
    "typescript": "~5.9.3",
    "ultracite": "^7.3.0"
  }
}
