{
  "name": "allmd-monorepo",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check-types": "turbo check-types",
    "typecheck": "turbo check-types",
    "test": "turbo test",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "turbo build --filter=allmd && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.20",
    "ultracite": "^7.2.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "npx ultracite fix"
    ]
  }
}
